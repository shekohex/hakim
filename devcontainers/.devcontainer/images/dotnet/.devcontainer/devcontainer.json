{
  "name": "Hakim Dotnet",
  "image": "ghcr.io/shekohex/hakim-tooling:latest",
  "build": {
    "args": {
      "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
    }
  },
  "features": {
    "../../../features/src/dotnet": {
      "version": "9.0",
      "additionalVersions": "10.0-preview"
    },
    "../../../features/src/lazyvim": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit"
      ]
    }
  },
  "runArgs": [
    "--privileged",
    "--cgroupns=host",
    "--tmpfs=/run",
    "--tmpfs=/run/lock",
    "--volume=/sys/fs/cgroup:/sys/fs/cgroup:rw"
  ],
  "remoteUser": "coder"
}
